{
  "name": "bigbad-meals",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": ["@firebase/util", "@google/genai", "esbuild", "msw", "protobufjs", "sharp"]
  },
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node build/server.js",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "preview": "vite preview",
    "clean": "rm -rf dist build",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:ui": "playwright test --ui",
    "deploy:cloudrun": "bash scripts/deploy-cloudrun.sh",
    "icons:generate": "node scripts/generate-icons.mjs",
    "pr:publish": "bash scripts/pr-publish.sh",
    "pr:publish:wait": "bash scripts/pr-publish.sh --wait",
    "pr:status": "bash scripts/pr-status.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.50.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
